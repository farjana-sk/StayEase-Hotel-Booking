
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayEase Hotel</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- ================= NAVBAR ================= -->

    <nav>

        <h2>🏨 StayEase</h2>

        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#rooms">Rooms</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>

    </nav>

    <!-- ================= HERO ================= -->

    <section id="home" class="hero">

        <div class="hero-content">

            <h1>Luxury Stays Made Simple</h1>

            <p>
                Experience comfort, elegance and unforgettable hospitality at StayEase Hotel.
            </p>

            <a href="/booking">
                <button>Book Now</button>
            </a>

        </div>

    </section>

    <!-- ================= FEATURED ROOMS ================= -->

    <section id="rooms" class="rooms">

        <h2>Featured Rooms</h2>

        <div class="room-container">

            <div class="room-card">

                <img src="/images/deluxe.jpg" alt="Deluxe Room">

                <h3>Deluxe Room</h3>

                <p>₹3,499 / Night</p>

                <button>Book Now</button>

            </div>

            <div class="room-card">

                <img src="/images/premium.jpg" alt="Premium Room">

                <h3>Premium Room</h3>

                <p>₹5,499 / Night</p>

                <button>Book Now</button>

            </div>

            <div class="room-card">

                <img src="/images/suite.jpg" alt="Suite Room">

                <h3>Suite Room</h3>

                <p>₹7,999 / Night</p>

                <button>Book Now</button>

            </div>

        </div>

    </section>

    <!-- ================= ABOUT ================= -->

    <section id="about" class="about">

        <div class="about-image">

            <img src="/images/about.jpg" alt="About StayEase">

        </div>

        <div class="about-content">

            <h2>About StayEase</h2>

            <p>
                StayEase Hotel offers luxurious rooms, exceptional hospitality,
                modern amenities, and a peaceful environment to ensure every
                guest enjoys a comfortable and memorable stay.
            </p>

            <button>Learn More</button>

        </div>

    </section>

    <!-- ================= CONTACT ================= -->

    <section id="contact" class="contact">

        <h2>Contact Us</h2>

        <p>Have any questions? We'd love to hear from you.</p>

        <div class="contact-container">

            <div class="contact-info">

                <h3>StayEase Hotel</h3>

                <p>📍 Hyderabad, Telangana</p>

                <p>📞 +91 98765 43210</p>

                <p>📧 stayease@gmail.com</p>

            </div>

            <form class="contact-form">

                <input
                    type="text"
                    placeholder="Your Name"
                    required>

                <input
                    type="email"
                    placeholder="Your Email"
                    required>

                <textarea
                    placeholder="Your Message"
                    required></textarea>

                <button type="submit">

                    Send Message

                </button>

            </form>

        </div>

    </section>

</body>

</html>
